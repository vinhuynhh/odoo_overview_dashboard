<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="odoo_overview_dashboard.OverviewSidebar">
        <aside class="o_overview_sidebar" aria-label="Overview navigation">
            <nav class="o_overview_sidebar_nav">
                <t t-foreach="props.navEntries" t-as="entry" t-key="entry.id">
                    <OverviewNavItem t-props="navItemProps(entry)"/>
                </t>
            </nav>
            <div class="o_overview_sidebar_footer">
                <button
                    type="button"
                    class="o_overview_sidebar_toggle"
                    t-att-title="props.toggleLabel"
                    t-att-aria-expanded="toggleAriaExpanded"
                    t-on-click="() => props.onToggleCollapsed()"
                >
                    <i
                        t-att-class="props.collapsed ? 'fa fa-angle-double-right' : 'fa fa-angle-double-left'"
                        aria-hidden="true"
                    />
                </button>
            </div>
        </aside>
    </t>
</templates>
